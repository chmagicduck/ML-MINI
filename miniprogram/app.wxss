/**app.wxss**/
page {
  background-color: #F8FAFC;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  /* 全局字体层级变量 */
  --font-xs: 20rpx;
  --font-sm: 22rpx;
  --font-base: 26rpx;
  --font-md: 28rpx;
  --font-lg: 30rpx;
  --font-xl: 32rpx;
  --font-2xl: 36rpx;
  --font-3xl: 40rpx;
  --font-4xl: 48rpx;
  --font-5xl: 64rpx;
}

/* ===== 通用卡片 ===== */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.07);
}

/* ===== 通用按钮 ===== */
.btn-primary {
  background: linear-gradient(135deg, #3B82F6, #2563EB);
  color: #fff;
  border-radius: 48rpx;
  padding: 20rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  border: none;
}

/* ===== 胶囊标签 ===== */
.pill {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 40rpx;
  font-size: 22rpx;
}
.pill-green {
  background: #EFF6FF;
  color: #1D4ED8;
}
.pill-red {
  background: #FFEBEE;
  color: #C62828;
}

/* ===== 导航条 ===== */
.nav-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx 16rpx;
}
