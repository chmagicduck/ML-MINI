/**app.wxss**/
page {
  background-color: #F0F4F0;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
  color: #333;
  box-sizing: border-box;
}

/* ===== 通用卡片 ===== */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.07);
}

/* ===== 通用按钮 ===== */
.btn-primary {
  background: linear-gradient(135deg, #66BB6A, #43A047);
  color: #fff;
  border-radius: 48rpx;
  padding: 20rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  border: none;
}

/* ===== 胶囊标签 ===== */
.pill {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 40rpx;
  font-size: 22rpx;
}
.pill-green {
  background: #E8F5E9;
  color: #388E3C;
}
.pill-red {
  background: #FFEBEE;
  color: #C62828;
}

/* ===== 导航条 ===== */
.nav-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx 16rpx;
}
