page {
  background: var(--deep-bg);
  color: var(--deep-text-primary);
  font-family: 'PingFang SC', 'Helvetica Neue', sans-serif;
}

:root {
  --deep-primary: #002FA7;
  --deep-primary-soft: #2B5FD7;
  --deep-mint: #A1E3E2;
  --deep-bg: #F0F4F8;
  --deep-surface: #FFFFFF;
  --deep-text-primary: #0E2A5C;
  --deep-text-secondary: #6D7E99;
  --deep-shadow: 0 8px 30px rgba(0,0,0,0.05);
  --deep-radius: 16px;
}

.deep-card {
  background: var(--deep-surface);
  border-radius: var(--deep-radius);
  box-shadow: var(--deep-shadow);
}
