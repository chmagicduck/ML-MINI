/* pages/data-manage/index.wxss — 数据管理 */

.page {
  min-height: 100vh;
  background: #F8FAFC;
  display: flex;
  flex-direction: column;
  padding: 24rpx 32rpx 0;
}

/* ===== 存储用量卡片 ===== */
.usage-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 24rpx;
}
.usage-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.usage-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #1E293B;
}
.usage-detail {
  font-size: 22rpx;
  font-weight: 700;
  color: #94A3B8;
}
.usage-bar-bg {
  height: 16rpx;
  background: #F1F5F9;
  border-radius: 16rpx;
  overflow: hidden;
}
.usage-bar-fill {
  height: 100%;
  background: linear-gradient(to right, #60A5FA, #3B82F6);
  border-radius: 16rpx;
  transition: width 0.3s ease;
}
.usage-hint {
  font-size: 20rpx;
  color: #94A3B8;
  font-weight: 700;
  display: block;
  margin-top: 8rpx;
}

/* ===== 模块分类卡片 ===== */
.modules-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 24rpx 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 24rpx;
}
.modules-title {
  font-size: 26rpx;
  font-weight: 800;
  color: #334155;
  margin-bottom: 16rpx;
  display: block;
}
.module-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F8FAFC;
}
.module-item:last-child {
  border-bottom: none;
}
.module-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.module-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #334155;
}
.module-size {
  font-size: 20rpx;
  color: #94A3B8;
  font-weight: 600;
}
.module-action {
  background: #FEF2F2;
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}
.module-action:active {
  opacity: 0.7;
}
.module-clear-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #EF4444;
}
.module-action-disabled {
  padding: 10rpx 24rpx;
  flex-shrink: 0;
}
.module-empty-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #D1D5DB;
}

/* ===== 全量重置 ===== */
.reset-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0;
}
.reset-btn {
  background: #FEF2F2;
  border: 1rpx solid #FECACA;
  border-radius: 48rpx;
  padding: 20rpx 64rpx;
}
.reset-btn:active {
  background: #FEE2E2;
}
.reset-btn-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #EF4444;
}
.reset-hint {
  font-size: 20rpx;
  color: #D1D5DB;
  font-weight: 600;
  display: block;
  margin-top: 12rpx;
}

/* ===== 底部安全区 ===== */
.safe-bottom { height: 120rpx; }
