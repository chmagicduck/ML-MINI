<view class="page">
  <view class="head">
    <text class="title">鱼额宝</text>
    <text class="sub">实时监控你的摸鱼利息。</text>
  </view>

  <view class="ring-card deep-card" bindtap="onToggleSlacking">
    <view class="liquid-ring" style="--p: {{progressPercent}}%;">
      <view class="wave wave1"></view>
      <view class="wave wave2"></view>
      <view class="inner">
        <text class="amount-label">今日鱼额</text>
        <text class="amount">{{animatedTodayEarnings}}</text>
        <text class="hint">{{isSlacking ? '资产增值中...' : '点击开始摸鱼'}}</text>
      </view>
    </view>
  </view>

  <button class="start-btn {{isSlacking ? 'active' : ''}}" bindtap="onToggleSlacking">
    <text>{{isSlacking ? '深潜中' : '开始摸鱼'}}</text>
    <view wx:if="{{isSlacking}}" class="ripple"></view>
  </button>

  <view class="board deep-card">
    <view class="row">
      <text class="k">今日摸鱼收入净值增长 (CNY)</text>
      <text class="v accent">{{todayEarnings}}</text>
    </view>
    <view class="row">
      <text class="k">职场牛马鱼权等级</text>
      <text class="v">{{levelName}}</text>
    </view>
    <view class="row">
      <text class="k">周末交割倒计时</text>
      <text class="v">{{daysToWeekend}} 天</text>
    </view>
    <view class="row">
      <text class="k">退休终极解套</text>
      <text class="v muted">{{daysToRetirement}} 天</text>
    </view>
  </view>
  <view style="height:120rpx"></view>
</view>
