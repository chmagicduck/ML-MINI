<!--index.wxml — 首页仪表盘 V2.2-->
<view class="page">

  <!-- V2.2 金币雨 Canvas（固定全屏，pointer-events:none） -->
  <canvas id="coin-rain-canvas" type="2d" class="coin-rain-canvas"></canvas>

  <!-- 自定义导航栏 -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px">
    <text class="nav-title">吗喽薪事🐒</text>
  </view>

  <!-- 节假日/周末特殊提示条 -->
  <view class="holiday-banner" wx:if="{{holidayText}}">
    <text class="holiday-text">🌴 {{holidayText}}</text>
  </view>

  <!-- 标语 -->
  <view class="slogan-bar">
    <text class="slogan-text">{{slogan}}</text>
  </view>

  <!-- 圆形进度仪表盘 -->
  <view class="dashboard-wrap">
    <view class="ring-outer {{isSlacking ? 'ring-glow' : ''}}" bindtap="onToggleSlacking">
      <view class="ring-track"></view>
      <view class="ring-progress" style="{{progressStyle}}"></view>
      <view class="ring-inner">
        <view class="status-badge {{isSlacking ? 'badge-active' : 'badge-idle'}}">
          <text class="badge-text">{{isSlacking ? '🐒 摸鱼中' : '🍃 待机中'}}</text>
        </view>
        <text class="timer-text">{{slackingTimeStr}}</text>
        <text class="timer-hint">{{isSlacking ? '点击暂停' : '点击开摸'}}</text>
      </view>
    </view>
    <text class="progress-label">{{timeUntilOffWork}}</text>
    <view class="progress-info" style="margin-top: 16rpx; font-size: 22rpx; color: #9E9E9E; text-align: center;">
      <text class="progress-detail">📊 今日工时: {{todayWorkedTimeStr}} | 摸鱼: {{todaySlackingTimeStr}}</text>
    </view>
  </view>

  <!-- 未配置薪资提示 -->
  <view class="tip-banner" wx:if="{{!hasSettings}}">
    <text class="tip-text">👆 前往「我的」填写薪资，才能看到真实收益</text>
  </view>

  <!-- 卡片网格 -->
  <view class="cards-container">

    <!-- ① 今日摸鱼收入（全宽） -->
    <view class="card card-highlight">
      <view class="card-row">
        <view>
          <text class="card-label">🤑 今日摸鱼收入</text>
          <text class="card-value value-pulse">{{todayEarnings}}</text>
          <text class="card-sub">{{secondSalary}}</text>
        </view>
        <text class="card-emoji-big">💸</text>
      </view>
    </view>

    <!-- ② V2.1 今日入账工资（全宽） -->
    <view class="card card-worked">
      <view class="card-row">
        <view>
          <text class="card-label">💼 今日入账工资</text>
          <text class="card-value value-worked value-pulse-blue">{{todayWorkedEarnings}}</text>
          <text class="card-sub">每秒入账 {{secondSalary}}</text>
        </view>
        <text class="card-emoji-big">🏦</text>
      </view>
    </view>

    <!-- ④ 本月已赚 + 距离发薪日 -->
    <view class="cards-row">
      <view class="card card-half">
        <text class="card-label">💰 本月已赚</text>
        <text class="card-value value-pulse">{{monthEarnings}}</text>
        <text class="card-sub">本月 {{workDaysInMonth}} 个工作日</text>
      </view>
      <view class="card card-half" bindtap="onGoToCalendar">
        <text class="card-label">📅 距离发薪日</text>
        <text class="card-value">{{daysToPayday}}</text>
        <text class="card-sub">天后发钱 →</text>
      </view>
    </view>

    <!-- ⑤ 距离周末 -->
    <view class="cards-row">
      <view class="card card-half">
        <text class="card-label">🎉 距离周末</text>
        <text class="card-value">{{daysToWeekend}}</text>
        <text class="card-sub">天后解放</text>
      </view>
    </view>

    <!-- ⑥ V2.1 计算说明（可折叠） -->
    <view class="calc-explain-wrap">
      <view class="calc-explain-header" bindtap="onToggleCalcExplain">
        <text class="calc-explain-title">📐 这些数字怎么算的？</text>
        <text class="calc-explain-arrow {{showCalcExplain ? 'arrow-up' : ''}}">▾</text>
      </view>
      <view class="calc-explain-body" wx:if="{{showCalcExplain}}">
        <view class="calc-row">
          <text class="calc-key">秒薪</text>
          <text class="calc-eq">= 月薪 ÷ 本月工作日数 ÷ 每日工作秒数</text>
        </view>
        <view class="calc-row">
          <text class="calc-key">今日摸鱼收入</text>
          <text class="calc-eq">= 秒薪 × 你主动开启计时的秒数</text>
        </view>
        <view class="calc-row">
          <text class="calc-key">今日入账工资</text>
          <text class="calc-eq">= 秒薪 × 今日已上班秒数（自动计算）</text>
        </view>
        <view class="calc-row">
          <text class="calc-key">本月已赚</text>
          <text class="calc-eq">= 已过工作日薪资 + 今日入账工资</text>
        </view>
        <view class="calc-divider"></view>
        <text class="calc-current">当前秒薪：¥{{secondSalaryValue}}/秒</text>
        <text class="calc-tip">* 基于你在「我的」中配置的月薪与工时计算</text>
      </view>
    </view>

  </view>

  <view class="safe-bottom"></view>
</view>
