<!--index.wxml — 领潮中心-->
<view class="page">

  <!-- 自定义导航栏 -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px">
    <view class="nav-left">
      <view class="nav-logo">潮</view>
      <text class="nav-title">薪潮涌动</text>
    </view>
    <view class="nav-capsule">
      <view class="capsule-dot"></view>
      <view class="capsule-sep"></view>
      <view class="capsule-ring"></view>
    </view>
  </view>

  <!-- 节假日/周末特殊提示条 -->
  <view class="holiday-banner" wx:if="{{holidayText}}">
    <text class="holiday-text">🌴 {{holidayText}}</text>
  </view>

  <!-- 圆形鱼缸计时器 -->
  <view class="timer-section">
    <view class="fish-bowl-outer" bindtap="onToggleSlacking">
      <view class="fish-bowl-ring" style="{{progressStyle}}"></view>
      <view class="fish-bowl-gap"></view>
      <view class="fish-bowl-inner">
        <view class="fish-bowl-bg">
          <!-- 光晕 -->
          <view class="bowl-glow"></view>
          <!-- 水面 -->
          <view class="water-fill {{isSlacking ? 'water-active' : ''}}">
            <view class="water-wave"></view>
          </view>
          <!-- 海草 -->
          <view class="seaweed seaweed-1"></view>
          <view class="seaweed seaweed-2"></view>
          <!-- 气泡 -->
          <view class="bubbles" wx:if="{{isSlacking}}">
            <view class="bubble bubble-1"></view>
            <view class="bubble bubble-2"></view>
            <view class="bubble bubble-3"></view>
          </view>
          <!-- 小鱼 -->
          <view class="fish-wrap {{isSlacking ? 'fish-swimming' : 'fish-idle'}}">
            <view class="fish-body">
              <view class="fish-eye">
                <view class="fish-pupil"></view>
              </view>
              <view class="fish-blush"></view>
              <view class="fish-dorsal"></view>
            </view>
            <view class="fish-tail-group">
              <view class="fish-tail-up"></view>
              <view class="fish-tail-down"></view>
            </view>
          </view>
        </view>
        <!-- 中心内容层 -->
        <view class="bowl-content">
          <text class="bowl-status {{isSlacking ? 'status-active' : 'status-idle'}}">{{isSlacking ? '正在摸鱼' : '休息中'}}</text>
          <text class="bowl-timer {{isSlacking ? 'timer-active' : 'timer-idle'}}">{{slackingTimeStr}}</text>
          <view class="bowl-btn {{isSlacking ? 'btn-active' : 'btn-idle'}}" catchtap="onToggleSlacking">
            <text class="btn-icon">{{isSlacking ? '■' : '▶'}}</text>
            <text class="btn-text">{{isSlacking ? '停止' : '开始'}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 未配置薪资提示 -->
  <view class="tip-banner" wx:if="{{!hasSettings}}">
    <text class="tip-text">👆 前往「我的」填写薪资，才能看到真实收益</text>
  </view>

  <!-- 工时进度条区域 -->
  <view class="progress-section">
    <view class="ring-legend">
      <view class="ring-legend-item">
        <view class="ring-dot ring-dot-work"></view>
        <text class="ring-legend-text">工作 {{workPctStr}}</text>
      </view>
      <view class="ring-legend-item">
        <view class="ring-dot ring-dot-moyu"></view>
        <text class="ring-legend-text ring-legend-text-moyu">摸鱼 {{moyuPctStr}}</text>
      </view>
      <view class="ring-legend-item" wx:if="{{hasFuture}}">
        <view class="ring-dot ring-dot-future"></view>
        <text class="ring-legend-text ring-legend-text-future">未到 {{futurePctStr}}</text>
      </view>
    </view>
    <view class="progress-card">
      <view class="progress-card-top">
        <text class="progress-label">退潮倒计时 {{offWorkPercent}}%</text>
        <view class="progress-dots">
          <view class="pdot {{offWorkPercent >= 20 ? 'pdot-on' : ''}}"></view>
          <view class="pdot {{offWorkPercent >= 40 ? 'pdot-on' : ''}}"></view>
          <view class="pdot {{offWorkPercent >= 60 ? 'pdot-on' : ''}}"></view>
          <view class="pdot {{offWorkPercent >= 80 ? 'pdot-on' : ''}}"></view>
          <view class="pdot {{offWorkPercent >= 100 ? 'pdot-on' : ''}}"></view>
        </view>
      </view>
      <view class="progress-bar-bg">
        <view class="progress-bar-fill" style="width: {{offWorkPercent}}%">
          <view class="progress-bar-shine"></view>
        </view>
      </view>
      <!-- 下班倒计时文字 -->
      <text class="countdown-text" wx:if="{{offWorkCountdown}}">{{offWorkCountdown}}</text>
    </view>
  </view>

  <!-- 数据卡片区 -->
  <view class="cards-area">

    <!-- 今日摸鱼收入大卡片 -->
    <view class="card-hero">
      <view class="card-hero-deco"></view>
      <view class="card-hero-body">
        <view class="card-hero-left">
          <view class="card-hero-label">
            <text class="card-hero-label-icon">💰</text>
            <text class="card-hero-label-text"> 今日摸鱼收入</text>
          </view>
          <text class="card-hero-value">{{todayEarnings}}</text>
        </view>
        <view class="card-hero-right">
          <text class="card-hero-tag-label">潮汐压强</text>
          <text class="card-hero-tag-value">{{secondSalary}}</text>
        </view>
      </view>
    </view>

    <!-- 2x2 数据网格 -->
    <view class="cards-grid">
      <!-- 今日入账 -->
      <view class="card-item card-warm">
        <view class="card-item-label">
          <text class="card-item-label-icon">☕</text>
          <text class="card-item-label-text"> 今日入账</text>
        </view>
        <text class="card-item-value card-value-warm">{{todayWorkedEarnings}}</text>
        <text class="card-item-sub">实时结算中</text>
      </view>

      <!-- 本月已赚 -->
      <view class="card-item card-white">
        <view class="card-item-label">
          <text class="card-item-label-icon">📈</text>
          <text class="card-item-label-text"> 本月已赚</text>
        </view>
        <text class="card-item-value card-value-green">{{monthEarnings}}</text>
        <text class="card-item-sub">{{workDaysInMonth}}个工作日</text>
      </view>

      <!-- 发薪倒数 -->
      <view class="card-item card-white" bindtap="onGoToCalendar">
        <view class="card-item-label">
          <text class="card-item-label-icon">📅</text>
          <text class="card-item-label-text"> 发薪倒数</text>
        </view>
        <view class="card-item-value-row">
          <text class="card-item-value card-value-dark">{{daysToPayday}}</text>
          <text class="card-item-unit">天</text>
        </view>
        <view class="card-item-link">
          <text class="card-item-link-text">查看明细</text>
          <text class="card-item-link-arrow"> ›</text>
        </view>
      </view>

      <!-- 距离周末 -->
      <view class="card-item card-white">
        <view class="card-item-label">
          <text class="card-item-label-icon">🌙</text>
          <text class="card-item-label-text"> 距离周末</text>
        </view>
        <view class="card-item-value-row">
          <text class="card-item-value card-value-dark">{{daysToWeekend}}</text>
          <text class="card-item-unit">天</text>
        </view>
        <text class="card-item-encourage">坚持住！</text>
      </view>
    </view>

    <!-- 计算说明（可折叠）保留 -->
    <view class="calc-explain-wrap">
      <view class="calc-explain-header" bindtap="onToggleCalcExplain">
        <text class="calc-explain-title">📐 这些数字怎么算的？</text>
        <text class="calc-explain-arrow {{showCalcExplain ? 'arrow-up' : ''}}">▾</text>
      </view>
      <view class="calc-explain-body" wx:if="{{showCalcExplain}}">
        <view class="calc-row">
          <text class="calc-key">秒薪</text>
          <text class="calc-eq">= 月薪 ÷ 本月工作日数 ÷ 每日工作秒数</text>
        </view>
        <view class="calc-row">
          <text class="calc-key">今日摸鱼收入</text>
          <text class="calc-eq">= 秒薪 × 你主动开启计时的秒数</text>
        </view>
        <view class="calc-row">
          <text class="calc-key">今日入账工资</text>
          <text class="calc-eq">= 秒薪 × 今日已上班秒数（自动计算）</text>
        </view>
        <view class="calc-row">
          <text class="calc-key">本月已赚</text>
          <text class="calc-eq">= 已过工作日薪资 + 今日入账工资</text>
        </view>
        <view class="calc-divider"></view>
        <text class="calc-current">当前秒薪：¥{{secondSalaryValue}}/秒</text>
        <text class="calc-tip">* 基于你在「我的」中配置的月薪与工时计算</text>
      </view>
    </view>

  </view>

  <view class="safe-bottom"></view>
</view>
