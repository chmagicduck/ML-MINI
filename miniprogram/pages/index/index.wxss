/* pages/index/index.wxss — V2 */

/* ===== 页面整体 ===== */
.page {
  min-height: 100vh;
  background: #F0F4F0;
  display: flex;
  flex-direction: column;
}

/* ===== 自定义导航栏 ===== */
.nav-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 12rpx 32rpx 16rpx;
  background: #E8F5E9;
}
.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2E7D32;
  letter-spacing: 2rpx;
}
.nav-placeholder {
  width: 80rpx;
}

/* ===== V2: 节假日提示横幅 ===== */
.holiday-banner {
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  padding: 14rpx 32rpx;
  border-bottom: 1rpx solid #A5D6A7;
}
.holiday-text {
  font-size: 26rpx;
  color: #2E7D32;
  font-weight: 600;
  display: block;
  text-align: center;
}

/* ===== 标语 ===== */
.slogan-bar {
  background: #E8F5E9;
  padding: 0 32rpx 20rpx;
}
.slogan-text {
  font-size: 22rpx;
  color: #66BB6A;
  display: block;
  text-align: center;
  font-style: italic;
}

/* ===== 圆形仪表盘 ===== */
.dashboard-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0 16rpx;
}

.ring-outer {
  position: relative;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
}
.ring-track {
  position: absolute;
  top: 0; left: 0;
  width: 300rpx; height: 300rpx;
  border-radius: 50%;
  background: #C8E6C9;
}
.ring-progress {
  position: absolute;
  top: 0; left: 0;
  width: 300rpx; height: 300rpx;
  border-radius: 50%;
}
.ring-inner {
  position: absolute;
  top: 28rpx; left: 28rpx;
  width: 244rpx; height: 244rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.08);
}

.status-badge {
  border-radius: 40rpx;
  padding: 6rpx 18rpx;
  margin-bottom: 12rpx;
}
.badge-idle { background: #E8F5E9; }
.badge-active {
  background: #FFEBEE;
  animation: badge-breathe 1.5s ease-in-out infinite;
}
@keyframes badge-breathe {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.6; }
}
.badge-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #333;
}
.timer-text {
  font-size: 42rpx;
  font-weight: 700;
  color: #1B5E20;
  letter-spacing: 2rpx;
  font-variant-numeric: tabular-nums;
}
.timer-hint {
  font-size: 20rpx;
  color: #9E9E9E;
  margin-top: 8rpx;
}
.progress-label {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #757575;
}

/* ===== 提示横幅 ===== */
.tip-banner {
  margin: 0 32rpx 16rpx;
  background: #FFF8E1;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
}
.tip-text {
  font-size: 24rpx;
  color: #F57F17;
  display: block;
  text-align: center;
}

/* ===== 卡片网格 ===== */
.cards-container {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 4rpx 32rpx 0;
}
.cards-row {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.07);
  box-sizing: border-box;
}
.card-half {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}
.card-highlight {
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  border: 1.5rpx solid #A5D6A7;
}

/* ===== V2: 等级卡片 ===== */
.card-level {
  border: 2rpx solid #9E9E9E;
}
.card-gold {
  background: linear-gradient(135deg, #FFFDE7, #FFF9C4);
  border-color: #FFD700 !important;
  box-shadow: 0 4rpx 20rpx rgba(255,215,0,0.3);
}
.level-badge-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  margin: 8rpx 0;
}
.level-emoji {
  font-size: 52rpx;
}
.level-name {
  font-size: 36rpx;
  font-weight: 700;
}

.card-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}
.card-label {
  font-size: 24rpx;
  color: #757575;
  display: block;
  margin-bottom: 8rpx;
}
.card-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #1B5E20;
  display: block;
  line-height: 1.1;
}
.card-value-sm {
  font-size: 36rpx;
}
.card-sub {
  font-size: 22rpx;
  color: #9E9E9E;
  display: block;
  margin-top: 8rpx;
}
.card-emoji-big { font-size: 80rpx; }
.card-right { margin-left: 16rpx; }

/* 数值跳动动画 */
.value-pulse {
  animation: pulse 0.3s ease-in-out infinite;
  color: #4CAF50;
}
@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.04); }
}

/* ===== 特色功能卡片 ===== */
.card-feature {
  align-items: flex-start;
  cursor: pointer;
  transition: transform 0.15s;
  background: linear-gradient(135deg, #fff, #F1F8E9);
}
.card-feature:active { transform: scale(0.97); }
.feature-icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 8rpx;
}
.feature-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 4rpx;
}
.feature-sub {
  font-size: 22rpx;
  color: #4CAF50;
  display: block;
}
.card-food {
  background: linear-gradient(135deg, #fff, #FFF8E1);
}
.food-subtitle {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-top: 4rpx;
}

/* ===== 底部安全区 ===== */
.safe-bottom { height: 120rpx; }
