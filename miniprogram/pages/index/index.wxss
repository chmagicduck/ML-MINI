.page{min-height:100vh;background:var(--deep-bg);padding:26rpx;}
.head{margin:16rpx 6rpx 22rpx;}.title{display:block;font-size:48rpx;color:var(--deep-primary);font-weight:800}.sub{display:block;color:var(--deep-text-secondary)}
.ring-card{padding:28rpx;border-radius:32rpx;box-shadow:var(--deep-shadow);}
.liquid-ring{position:relative;width:420rpx;height:420rpx;margin:0 auto;border-radius:50%;background:conic-gradient(var(--deep-primary) var(--p), #dbe7ff var(--p));display:flex;align-items:center;justify-content:center;overflow:hidden}
.inner{position:absolute;width:320rpx;height:320rpx;border-radius:50%;background:#fff;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:3}
.amount-label{font-size:26rpx;color:var(--deep-text-secondary)}.amount{font-size:54rpx;color:var(--deep-primary);font-weight:800}.hint{color:#6d90c9;font-size:24rpx}
.wave{position:absolute;width:600rpx;height:600rpx;left:-90rpx;border-radius:42%;background:rgba(161,227,226,.6);bottom:calc(-430rpx + var(--p));animation:spin 6s linear infinite}
.wave2{background:rgba(161,227,226,.35);animation-duration:9s}
@keyframes spin{from{transform:rotate(0)}to{transform:rotate(360deg)}}
.start-btn{margin:26rpx auto;width:86%;border-radius:999rpx;background:var(--deep-primary);color:#fff;position:relative;overflow:hidden}.start-btn.active{background:#0a5ed8}
.ripple{position:absolute;left:50%;top:50%;width:40rpx;height:40rpx;border-radius:50%;background:rgba(161,227,226,.45);transform:translate(-50%,-50%);animation:ripple 1.2s infinite}
@keyframes ripple{to{width:600rpx;height:600rpx;opacity:0}}
.board{padding:18rpx 26rpx;border-radius:24rpx;box-shadow:var(--deep-shadow)}
.row{display:flex;justify-content:space-between;padding:18rpx 0;border-bottom:1rpx solid #edf1f8}.row:last-child{border:0}
.k{color:var(--deep-text-secondary);font-size:24rpx}.v{color:var(--deep-text-primary);font-weight:700}.accent{color:var(--deep-primary)}.muted{font-size:24rpx;color:#9aa7bd}
