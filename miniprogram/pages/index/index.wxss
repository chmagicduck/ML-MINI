/* pages/index/index.wxss — 鱼额宝首页 */

.page {
  min-height: 100vh;
  background: #F8FAFC;
  display: flex;
  flex-direction: column;
}

/* ===== 自定义导航栏 ===== */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 32rpx 16rpx;
  background: #FFFFFF;
}
.nav-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.nav-logo {
  width: 48rpx;
  height: 48rpx;
  background: #2563EB;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 800;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.3);
}
.nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}
.nav-capsule {
  width: 160rpx;
  height: 56rpx;
  background: rgba(242, 242, 242, 0.5);
  border-radius: 56rpx;
  border: 1rpx solid rgba(0,0,0,0.06);
  display: flex;
  align-items: center;
  justify-content: space-evenly;
  opacity: 0.3;
}
.capsule-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.2);
}
.capsule-sep {
  width: 1rpx;
  height: 24rpx;
  background: rgba(0,0,0,0.1);
}
.capsule-ring {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(0,0,0,0.2);
}

/* ===== 节假日横幅 ===== */
.holiday-banner {
  background: linear-gradient(135deg, #EFF6FF, #DBEAFE);
  padding: 14rpx 32rpx;
  border-bottom: 1rpx solid #BFDBFE;
}
.holiday-text {
  font-size: 26rpx;
  color: #1D4ED8;
  font-weight: 600;
  display: block;
  text-align: center;
}

/* ===== 圆形鱼缸计时器 ===== */
.timer-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0 16rpx;
}

.fish-bowl-outer {
  position: relative;
  width: 448rpx;
  height: 448rpx;
  border-radius: 50%;
  overflow: hidden;
  transform: translateZ(0);
}

.fish-bowl-ring {
  position: absolute;
  top: 0; left: 0;
  width: 448rpx;
  height: 448rpx;
  border-radius: 50%;
}

.fish-bowl-gap {
  position: absolute;
  top: 12rpx; left: 12rpx;
  width: 424rpx; height: 424rpx;
  border-radius: 50%;
  background: #FFFFFF;
}

.fish-bowl-inner {
  position: absolute;
  top: 16rpx; left: 16rpx;
  width: 416rpx;
  height: 416rpx;
  border-radius: 50%;
  background: #FFFFFF;
  overflow: hidden;
}

.fish-bowl-bg {
  position: absolute;
  top: 16rpx; left: 16rpx; right: 16rpx; bottom: 16rpx;
  border-radius: 50%;
  background: linear-gradient(to bottom, #E0F2FE, #F0F9FF);
  box-shadow: inset 0 8rpx 24rpx rgba(0,0,0,0.05);
  overflow: hidden;
}

.bowl-glow {
  position: absolute;
  top: -32rpx; left: -32rpx;
  width: 256rpx; height: 256rpx;
  background: rgba(255,255,255,0.4);
  border-radius: 50%;
  filter: blur(40rpx);
}

/* 水面 */
.water-fill {
  position: absolute;
  bottom: 0;
  width: 100%;
  height: 25%;
  background: rgba(96, 165, 250, 0.1);
  transition: height 1s ease;
}
.water-active { height: 45%; }
.water-wave {
  position: absolute;
  top: 0;
  width: 200%;
  height: 48rpx;
  background: rgba(147, 197, 253, 0.1);
  transform: translateY(-50%);
  animation: wave-slow 6s linear infinite;
}

/* 气泡 */
.bubbles { position: absolute; inset: 0; pointer-events: none; }
.bubble {
  position: absolute;
  background: rgba(255,255,255,0.4);
  border-radius: 50%;
}
.bubble-1 {
  bottom: 16rpx; left: 33%;
  width: 12rpx; height: 12rpx;
  animation: bubble-rise 4s ease-in infinite;
}
.bubble-2 {
  bottom: 32rpx; left: 50%;
  width: 8rpx; height: 8rpx;
  animation: bubble-rise 4s ease-in infinite 1.2s;
}
.bubble-3 {
  bottom: 48rpx; right: 25%;
  width: 16rpx; height: 16rpx;
  background: rgba(255,255,255,0.5);
  animation: bubble-rise 4s ease-in infinite 0.6s;
}

/* 海草 */
.seaweed {
  position: absolute;
  border-radius: 50%;
  filter: blur(1rpx);
}
.seaweed-1 {
  bottom: -20rpx; left: 25%;
  width: 16rpx; height: 128rpx;
  background: rgba(74, 222, 128, 0.2);
  animation: grass-sway 3s ease-in-out infinite;
}
.seaweed-2 {
  bottom: -10rpx; right: 33%;
  width: 12rpx; height: 96rpx;
  background: rgba(34, 197, 94, 0.2);
  animation: grass-sway 3s ease-in-out infinite 0.8s;
}

/* 小鱼 CSS */
.fish-wrap {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx; height: 80rpx;
}
.fish-swimming { animation: fish-patrol 10s ease-in-out infinite; }
.fish-idle { opacity: 0.4; filter: grayscale(0.5); }

.fish-body {
  position: absolute;
  left: 50%; top: 50%;
  transform: translate(-50%, -50%);
  width: 96rpx; height: 56rpx;
  background: linear-gradient(to right, #F97316, #FB923C);
  border-radius: 50% 60% 60% 50%;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}
.fish-eye {
  position: absolute;
  right: 16rpx; top: 16rpx;
  width: 16rpx; height: 16rpx;
  background: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.fish-pupil {
  width: 8rpx; height: 8rpx;
  background: #000000;
  border-radius: 50%;
}
.fish-blush {
  position: absolute;
  right: 24rpx; bottom: 12rpx;
  width: 16rpx; height: 8rpx;
  background: rgba(248, 113, 113, 0.2);
  border-radius: 50%;
}
.fish-dorsal {
  position: absolute;
  top: -8rpx; left: 32rpx;
  width: 32rpx; height: 24rpx;
  background: #EA580C;
  border-radius: 100% 0% 0% 0%;
  transform: rotate(-15deg);
}

.fish-tail-group {
  position: absolute;
  left: 16rpx; top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
}
.fish-tail-up {
  width: 40rpx; height: 32rpx;
  background: #EA580C;
  border-radius: 0% 100% 20% 100%;
  transform-origin: right center;
  animation: tail-up 0.5s ease-in-out infinite;
}
.fish-tail-down {
  width: 40rpx; height: 32rpx;
  background: #EA580C;
  border-radius: 100% 20% 100% 0%;
  transform-origin: right center;
  margin-top: -8rpx;
  animation: tail-down 0.5s ease-in-out infinite;
}

/* 中心内容 */
.bowl-content {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 10;
  pointer-events: none;
}

.bowl-status {
  font-size: 20rpx;
  font-weight: 700;
  margin-bottom: 4rpx;
}
.status-active { color: rgba(37, 99, 235, 0.8); }
.status-idle { color: #9CA3AF; }

.bowl-timer {
  font-size: 64rpx;
  font-weight: 800;
  letter-spacing: -2rpx;
  line-height: 1;
  font-variant-numeric: tabular-nums;
}
.timer-active { color: #1E3A8A; }
.timer-idle { color: #D1D5DB; }

.bowl-btn {
  margin-top: 32rpx;
  pointer-events: auto;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  font-size: 22rpx;
  font-weight: 800;
  transition: all 0.2s;
}
.bowl-btn:active { transform: scale(0.9); }
.btn-active {
  background: #2563EB;
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.3);
}
.btn-idle {
  background: #F3F4F6;
  color: #6B7280;
}
.btn-icon { font-size: 16rpx; }
.btn-text { font-size: 22rpx; }

/* ===== 提示横幅 ===== */
.tip-banner {
  margin: 0 32rpx 16rpx;
  background: #FEF3C7;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
}
.tip-text { font-size: 24rpx; color: #92400E; display: block; text-align: center; }

/* ===== 工时进度条 ===== */
.progress-section {
  padding: 0 48rpx;
  margin-top: 24rpx;
}
.progress-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}
.progress-time {
  display: flex;
  align-items: center;
  font-size: 20rpx;
  font-weight: 700;
  color: #94A3B8;
}
.progress-time-icon { color: #60A5FA; }
.progress-time-text { color: #94A3B8; }
.progress-ratio {
  font-size: 20rpx;
  font-weight: 700;
  color: #2563EB;
  background: #EFF6FF;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}

.progress-card {
  background: rgba(249, 250, 251, 0.8);
  border-radius: 32rpx;
  padding: 28rpx;
  border: 1rpx solid #F3F4F6;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.progress-card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.progress-label {
  font-size: 22rpx;
  font-weight: 800;
  color: #475569;
}
.progress-dots {
  display: flex;
  gap: 8rpx;
}
.pdot {
  width: 24rpx;
  height: 8rpx;
  border-radius: 8rpx;
  background: #E5E7EB;
}
.pdot-on { background: #3B82F6; }

.progress-bar-bg {
  height: 16rpx;
  width: 100%;
  background: rgba(229, 231, 235, 0.4);
  border-radius: 16rpx;
  overflow: hidden;
}
.progress-bar-fill {
  height: 100%;
  background: linear-gradient(to right, #60A5FA, #2563EB);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(37, 99, 235, 0.2);
  position: relative;
  transition: width 0.5s ease;
}
.progress-bar-shine {
  position: absolute;
  inset: 0;
  background: rgba(255,255,255,0.2);
  animation: pulse-shine 2s ease-in-out infinite;
}

/* ===== 数据卡片区 ===== */
.cards-area {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 32rpx 32rpx 0;
}

/* 今日摸鱼收入大卡片 */
.card-hero {
  background: #1E40AF;
  border-radius: 56rpx;
  padding: 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(30, 64, 175, 0.2);
  position: relative;
  overflow: hidden;
}
.card-hero-deco {
  position: absolute;
  top: 0; right: 0;
  width: 256rpx; height: 256rpx;
  background: rgba(255,255,255,0.05);
  border-radius: 50%;
  transform: translate(50%, -50%);
}
.card-hero-body {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  position: relative;
  z-index: 1;
}
.card-hero-left { flex: 1; }
.card-hero-label {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}
.card-hero-label-icon {
  font-size: 28rpx;
  opacity: 0.7;
}
.card-hero-label-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #93C5FD;
}
.card-hero-value {
  font-size: 68rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: -2rpx;
  line-height: 1;
  display: block;
}
.card-hero-right {
  background: rgba(255,255,255,0.1);
  backdrop-filter: blur(10rpx);
  padding: 12rpx 16rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
  text-align: right;
  margin-left: 16rpx;
  flex-shrink: 0;
}
.card-hero-tag-label {
  font-size: 16rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.5);
  display: block;
  text-transform: uppercase;
}
.card-hero-tag-value {
  font-size: 22rpx;
  font-weight: 800;
  color: #FFFFFF;
  display: block;
}

/* 2x2 数据网格 */
.cards-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  padding-bottom: 16rpx;
}

.card-item {
  border-radius: 48rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  min-height: 130rpx;
}
.card-warm {
  background: #FFFBF5;
  border: 1rpx solid rgba(234, 179, 8, 0.15);
}
.card-white {
  background: #FFFFFF;
  border: 1rpx solid #F3F4F6;
}

.card-item-label {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}
.card-item-label-icon { font-size: 26rpx; }
.card-item-label-text {
  font-size: 22rpx;
  font-weight: 800;
  color: #64748B;
}

.card-item-value {
  font-size: 40rpx;
  font-weight: 800;
  display: block;
  line-height: 1.1;
}
.card-value-warm { color: #C2410C; }
.card-value-green { color: #16A34A; }
.card-value-dark { color: #1E293B; font-size: 44rpx; }

.card-item-sub {
  font-size: 20rpx;
  color: #94A3B8;
  font-weight: 600;
  display: block;
  margin-top: 8rpx;
}

.card-item-value-row {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}
.card-item-unit {
  font-size: 20rpx;
  color: #9CA3AF;
  font-weight: 700;
  margin-left: 4rpx;
}

.card-item-link {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}
.card-item-link-text {
  font-size: 18rpx;
  color: #3B82F6;
  font-weight: 700;
}
.card-item-link-arrow {
  font-size: 20rpx;
  color: #3B82F6;
}

.card-item-encourage {
  font-size: 18rpx;
  color: #818CF8;
  font-weight: 700;
  font-style: italic;
  display: block;
  margin-top: 8rpx;
}

/* ===== 计算说明 ===== */
.calc-explain-wrap {
  background: #FFFFFF;
  border-radius: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  overflow: hidden;
  border: 1rpx solid #F3F4F6;
}
.calc-explain-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
}
.calc-explain-header:active { background: #F9FAFB; }
.calc-explain-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #555;
}
.calc-explain-arrow {
  font-size: 32rpx;
  color: #9CA3AF;
  transition: transform 0.2s;
  display: block;
}
.arrow-up { transform: rotate(180deg); }

.calc-explain-body {
  padding: 0 28rpx 24rpx;
  border-top: 1rpx solid #F3F4F6;
}
.calc-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 12rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx dashed #F3F4F6;
}
.calc-key {
  font-size: 24rpx;
  font-weight: 600;
  color: #1D4ED8;
  min-width: 180rpx;
  flex-shrink: 0;
}
.calc-eq {
  font-size: 24rpx;
  color: #555;
  flex: 1;
  line-height: 1.5;
}
.calc-divider { height: 16rpx; }
.calc-current {
  font-size: 26rpx;
  font-weight: 700;
  color: #1E3A8A;
  display: block;
  margin-top: 8rpx;
}
.calc-tip {
  font-size: 22rpx;
  color: #9CA3AF;
  display: block;
  margin-top: 8rpx;
}

/* ===== 底部安全区 ===== */
.safe-bottom { height: 120rpx; }

/* ===== 动画 ===== */
@keyframes wave-slow {
  0% { transform: translateX(0) translateY(-50%); }
  100% { transform: translateX(-50%) translateY(-50%); }
}

@keyframes bubble-rise {
  0% { transform: translateY(0); opacity: 0; }
  20% { opacity: 0.6; }
  100% { transform: translateY(-160rpx); opacity: 0; }
}

@keyframes fish-patrol {
  0% { transform: translate(-80%, -40%) scaleX(1); }
  45% { transform: translate(10%, -60%) scaleX(1); }
  50% { transform: translate(10%, -60%) scaleX(-1); }
  95% { transform: translate(-80%, -40%) scaleX(-1); }
  100% { transform: translate(-80%, -40%) scaleX(1); }
}

@keyframes tail-up {
  0%, 100% { transform: rotate(10deg); }
  50% { transform: rotate(30deg); }
}

@keyframes tail-down {
  0%, 100% { transform: rotate(-10deg); }
  50% { transform: rotate(-30deg); }
}

@keyframes pulse-shine {
  0%, 100% { opacity: 0.15; }
  50% { opacity: 0.35; }
}

@keyframes grass-sway {
  0%, 100% { transform: rotate(-5deg); transform-origin: bottom center; }
  50% { transform: rotate(5deg); transform-origin: bottom center; }
}
