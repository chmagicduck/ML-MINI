<!--pages/lab/index.wxml — 深海动力室-->
<view class="page">

  <!-- 功能列表卡片 -->
  <view class="lab-card">
    <view class="lab-item" bindtap="onGoToMeeting">
      <view class="lab-item-icon icon-meeting">
        <text class="icon-text">💸</text>
      </view>
      <view class="lab-item-info">
        <text class="lab-item-title">烧钱会议室</text>
        <text class="lab-item-desc">实时计算会议成本，感受燃烧的钱</text>
      </view>
      <text class="lab-item-arrow">›</text>
    </view>

    <view class="lab-divider"></view>

    <view class="lab-item" bindtap="onGoToPoop">
      <view class="lab-item-icon icon-poop">
        <text class="icon-text">💩</text>
      </view>
      <view class="lab-item-info">
        <text class="lab-item-title">带薪拉粑粑</text>
        <text class="lab-item-desc">如厕即赚钱，记录年度如厕收益</text>
      </view>
      <text class="lab-item-arrow">›</text>
    </view>

    <view class="lab-divider"></view>

    <view class="lab-item" bindtap="onGoToFood">
      <view class="lab-item-icon icon-food">
        <text class="icon-text">🍱</text>
      </view>
      <view class="lab-item-info">
        <text class="lab-item-title">今天吃什么</text>
        <text class="lab-item-desc">选择困难症救星，帮你做决定</text>
      </view>
      <text class="lab-item-arrow">›</text>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
