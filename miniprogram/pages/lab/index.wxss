/* pages/lab/index.wxss — 深海动力室 */

.page {
  min-height: 100vh;
  background: #F8FAFC;
  display: flex;
  flex-direction: column;
  padding: 24rpx 40rpx 0;
}

/* ===== 功能列表卡片 ===== */
.lab-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 8rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.lab-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
}
.lab-item:active {
  background: #F9FAFB;
}

.lab-item-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.icon-meeting { background: #FFF8E1; }
.icon-poop { background: #EFEBE9; }
.icon-food { background: #E8F5E9; }
.icon-text { font-size: 40rpx; }

.lab-item-info {
  flex: 1;
  margin-left: 24rpx;
}
.lab-item-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #1E293B;
  display: block;
}
.lab-item-desc {
  font-size: 24rpx;
  color: #94A3B8;
  font-weight: 600;
  display: block;
  margin-top: 6rpx;
}

.lab-item-arrow {
  font-size: 36rpx;
  color: #CBD5E1;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.lab-divider {
  height: 1rpx;
  background: #F3F4F6;
  margin: 0 32rpx;
}

/* ===== 底部安全区 ===== */
.safe-bottom { height: 120rpx; }
