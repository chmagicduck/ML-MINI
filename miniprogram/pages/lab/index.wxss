/* pages/lab/index.wxss — 实验室 */

.page {
  min-height: 100vh;
  background: #F0F4F0;
  display: flex;
  flex-direction: column;
}

/* ===== 页头 ===== */
.page-header {
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  padding: 48rpx 40rpx 36rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1B5E20;
}
.page-sub {
  font-size: 26rpx;
  color: #4CAF50;
}

/* ===== 工具列表 ===== */
.tools-list {
  display: flex;
  flex-direction: column;
  gap: 0;
  margin: 32rpx 32rpx 0;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.07);
}

.tool-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 32rpx 28rpx;
  gap: 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
  transition: background 0.15s;
}
.tool-card:last-child { border-bottom: none; }
.tool-card:active { background: #F9FBF9; }

.tool-icon {
  font-size: 64rpx;
  flex-shrink: 0;
}
.tool-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.tool-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1B5E20;
}
.tool-desc {
  font-size: 24rpx;
  color: #9E9E9E;
  line-height: 1.4;
}
.tool-arrow {
  font-size: 40rpx;
  color: #C8E6C9;
  flex-shrink: 0;
}

/* ===== 底部安全区 ===== */
.safe-bottom { height: 120rpx; }
