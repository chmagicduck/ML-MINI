<!--pages/meeting-history/index.wxml — 会议历史记录-->
<view class="page">
  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{isEmpty && !isLoading}}">
    <text class="empty-icon">📭</text>
    <text class="empty-text">还没有会议记录</text>
    <text class="empty-hint">去开一场烧钱会议吧！</text>
  </view>

  <!-- 列表 -->
  <view class="record-list" wx:if="{{!isEmpty}}">
    <view
      class="record-card"
      wx:for="{{records}}"
      wx:key="id"
    >
      <!-- 编辑模式 -->
      <view class="edit-area" wx:if="{{editingId === item.id}}">
        <view class="edit-row">
          <text class="edit-label">会议名称</text>
          <input
            class="edit-input"
            value="{{editName}}"
            bindinput="onEditNameInput"
            maxlength="30"
            placeholder="输入会议名称"
          />
        </view>
        <view class="edit-row">
          <text class="edit-label">参会人数</text>
          <input
            class="edit-input"
            type="number"
            value="{{editParticipants}}"
            bindinput="onEditParticipantsInput"
            placeholder="1-50"
          />
        </view>
        <view class="edit-btn-row">
          <view class="edit-btn edit-btn-cancel" bindtap="onCancelEdit">
            <text class="edit-btn-text">取消</text>
          </view>
          <view class="edit-btn edit-btn-save" bindtap="onSaveEdit">
            <text class="edit-btn-text-save">保存</text>
          </view>
        </view>
      </view>

      <!-- 展示模式 -->
      <view class="record-content" wx:else>
        <view class="record-header">
          <text class="record-name">{{item.name}}</text>
          <text class="record-date">{{item.dateDisplay}}</text>
        </view>
        <view class="record-details">
          <view class="detail-item">
            <text class="detail-label">参会</text>
            <text class="detail-value">{{item.participants}}人</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">费用</text>
            <text class="detail-value detail-cost">{{item.totalCostDisplay}}</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">时长</text>
            <text class="detail-value">{{item.durationDisplay}}</text>
          </view>
        </view>
        <view class="record-actions">
          <view class="action-btn" data-id="{{item.id}}" bindtap="onStartEdit">
            <text class="action-text action-edit">编辑</text>
          </view>
          <button
            class="action-btn action-share-btn"
            open-type="share"
            data-id="{{item.id}}"
            bindtap="onSelectForShare"
          >
            <text class="action-text action-share">分享</text>
          </button>
          <view class="action-btn" data-id="{{item.id}}" bindtap="onDelete">
            <text class="action-text action-delete">删除</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 分页控制 -->
  <view class="pagination" wx:if="{{totalPages > 1}}">
    <view
      class="page-btn {{currentPage <= 1 ? 'page-btn-disabled' : ''}}"
      bindtap="onPrevPage"
    >
      <text class="page-btn-text">上一页</text>
    </view>
    <text class="page-info">{{currentPage}} / {{totalPages}}</text>
    <view
      class="page-btn {{currentPage >= totalPages ? 'page-btn-disabled' : ''}}"
      bindtap="onNextPage"
    >
      <text class="page-btn-text">下一页</text>
    </view>
  </view>

  <!-- 总计 -->
  <view class="total-bar" wx:if="{{!isEmpty}}">
    <text class="total-text">共 {{totalCount}} 条会议记录</text>
  </view>

  <view class="safe-bottom"></view>
</view>
