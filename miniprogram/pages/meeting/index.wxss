.avatar-pos-40 { top: 50rpx; right: 10rpx; }
.avatar-pos-41 { top: 145rpx; right: 10rpx; }
.avatar-pos-42 { top: 240rpx; right: 10rpx; }
.avatar-pos-43 { top: 310rpx; right: 24rpx; }
.avatar-pos-44 { bottom: 10rpx; left: 440rpx; }
.avatar-pos-45 { bottom: 10rpx; left: 330rpx; }
.avatar-pos-46 { bottom: 10rpx; left: 170rpx; }
.avatar-pos-47 { bottom: 10rpx; left: 55rpx; }
.avatar-pos-48 { top: 310rpx; left: 24rpx; }
.avatar-pos-49 { top: 50rpx; left: 10rpx; }

/* ===== 动画 ===== */
@keyframes popIn {
  0% { transform: scale(0); opacity: 0; }
  80% { transform: scale(1.3); opacity: 1; }
  100% { transform: scale(1); opacity: 1; }
}
@keyframes fireGlow {
  0% { text-shadow: 0 0 10px rgba(239,68,68,0.3); transform: scale(1); }
  50% { text-shadow: 0 0 25px rgba(239,68,68,0.9); transform: scale(1.02); }
  100% { text-shadow: 0 0 10px rgba(239,68,68,0.3); transform: scale(1); }
}
@keyframes wiggle {
  0%, 100% { transform: rotate(-5deg); }
  50% { transform: rotate(5deg); }
}
@keyframes pulseGlow {
  0%, 100% { opacity: 0.4; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.3); }
}

/* ===== 会议名称输入 ===== */
.name-input-wrap {
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}
.name-input {
  font-size: 30rpx;
  color: #333;
}

/* ===== 参会人数卡片 ===== */
.section-card {
  margin: 24rpx 32rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.07);
}
.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}
.participants-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 48rpx;
  margin-bottom: 20rpx;
}
.adj-btn {
  width: 72rpx;
  height: 72rpx;
  background: #EFF6FF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}
.adj-btn:active { transform: scale(0.92); }
.adj-icon {
  font-size: 44rpx;
  font-weight: 700;
  color: #2563EB;
  line-height: 1;
}
.participants-num {
  font-size: 52rpx;
  font-weight: 700;
  color: #1E40AF;
  min-width: 160rpx;
  text-align: center;
}
.participants-slider {
  margin: 8rpx 0;
}
.slider-hint {
  font-size: 22rpx;
  color: #9E9E9E;
  display: block;
  text-align: center;
  margin-top: 8rpx;
}

/* ===== 自定义月薪 ===== */
.custom-salary-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 4rpx;
}
.custom-salary-body {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F0F0;
}
.custom-salary-label {
  font-size: 24rpx;
  color: #757575;
  display: block;
  margin-bottom: 12rpx;
}
.custom-salary-input-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  gap: 8rpx;
}
.salary-prefix {
  font-size: 32rpx;
  font-weight: 700;
  color: #2563EB;
}
.custom-salary-input {
  flex: 1;
  font-size: 32rpx;
  color: #333;
}
.custom-salary-hint {
  font-size: 22rpx;
  color: #BDBDBD;
  display: block;
  margin-top: 10rpx;
}

/* ===== 控制按钮 ===== */
.btn-row {
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.btn-main {
  border-radius: 48rpx;
  padding: 28rpx 0;
  text-align: center;
}
.btn-main:active { opacity: 0.85; }
.btn-start {
  background: linear-gradient(135deg, #60A5FA, #2563EB);
  box-shadow: 0 8rpx 24rpx rgba(37,99,235,0.4);
}
.btn-stop {
  background: linear-gradient(135deg, #FCA5A5, #EF4444);
  box-shadow: 0 8rpx 24rpx rgba(239,68,68,0.3);
}
.btn-main-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
}
.btn-end {
  background: linear-gradient(135deg, #FBBF24, #F59E0B);
  border-radius: 48rpx;
  padding: 24rpx 0;
  text-align: center;
  box-shadow: 0 6rpx 20rpx rgba(245, 158, 11, 0.3);
}
.btn-end:active { opacity: 0.85; }
.btn-end-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
}
.btn-reset {
  background: #FFFFFF;
  border-radius: 48rpx;
  padding: 24rpx 0;
  text-align: center;
  border: 1.5rpx solid #E0E0E0;
}
.btn-reset:active { background: #F5F5F5; }
.btn-reset-text {
  font-size: 30rpx;
  color: #757575;
}

/* ===== 分享按钮 ===== */
.btn-share-meeting {
  background: #FFFFFF;
  border-radius: 48rpx;
  padding: 24rpx 0;
  text-align: center;
  border: 1.5rpx solid #93C5FD;
  margin: 0;
}
.btn-share-meeting::after { border: none; }
.btn-share-meeting:active { background: #EFF6FF; }
.btn-share-meeting-text {
  font-size: 30rpx;
  color: #2563EB;
}

/* ===== 查看过往会议入口 ===== */
.history-entry {
  margin: 24rpx 32rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.07);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}
.history-entry:active { background: #F8FAFC; }
.history-entry-text {
  font-size: 28rpx;
  color: #2563EB;
  font-weight: 600;
}
.history-entry-arrow {
  font-size: 36rpx;
  color: #9E9E9E;
}

/* ===== 趣味提示 ===== */
.fun-tips {
  margin: 24rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.fun-tip {
  font-size: 24rpx;
  color: #9E9E9E;
  display: block;
  text-align: center;
}

/* ===== 底部安全区 ===== */
.safe-bottom { height: 80rpx; }
