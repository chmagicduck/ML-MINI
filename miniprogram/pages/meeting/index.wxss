/* pages/meeting/index.wxss — 烧钱会议机（重构版） */

.page {
  min-height: 100vh;
  background: #F8FAFC;
  display: flex;
  flex-direction: column;
}

/* ===== 提示条 ===== */
.tip-banner {
  background: #FFF8E1;
  padding: 16rpx 32rpx;
  border-bottom: 1rpx solid #FFE082;
}
.tip-text {
  font-size: 24rpx;
  color: #F57F17;
  display: block;
  text-align: center;
}

/* ===== 金额显示区 ===== */
.burn-display {
  background: #FFFFFF;
  padding: 48rpx 32rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-bottom: 1rpx solid #EEEEEE;
}
.burn-label {
  font-size: 26rpx;
  color: #757575;
  display: block;
  margin-bottom: 12rpx;
}
.burn-amount-row {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  justify-content: center;
}
.burn-currency {
  font-size: 48rpx;
  font-weight: 700;
  color: #C62828;
  margin-right: 4rpx;
}
.burn-amount {
  font-size: 80rpx;
  font-weight: 700;
  color: #C62828;
  font-variant-numeric: tabular-nums;
  line-height: 1.2;
}
.fire-glow {
  animation: fireGlow 1.5s ease-in-out infinite;
}
.burn-rate {
  font-size: 26rpx;
  color: #9E9E9E;
  display: block;
  margin-top: 8rpx;
}
.burn-elapsed {
  font-size: 24rpx;
  color: #BDBDBD;
  display: block;
  margin-top: 4rpx;
  font-variant-numeric: tabular-nums;
}

/* ===== 会议桌可视化 ===== */
.table-scene {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0 16rpx;
}
.table-container {
  position: relative;
  width: 560rpx;
  height: 400rpx;
  background: #1E293B;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  transition: box-shadow 0.3s;
}
.table-container-active {
  box-shadow: 0 0 40rpx rgba(239, 68, 68, 0.25);
}
.meeting-table {
  width: 220rpx;
  height: 130rpx;
  background: linear-gradient(135deg, #92400E, #B45309, #D97706);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.4);
  transition: box-shadow 0.3s;
  z-index: 2;
}
.meeting-table-active {
  box-shadow: 0 0 30rpx rgba(239, 68, 68, 0.5), 0 8rpx 24rpx rgba(0, 0, 0, 0.4);
}
.table-fire {
  font-size: 48rpx;
}
.table-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}
.table-count {
  font-size: 24rpx;
  color: #9E9E9E;
  margin-top: 12rpx;
}

/* ===== 头像定位（最多50人，分布在容器边缘） ===== */
.avatar-slot {
  position: absolute;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: popIn 0.4s ease-out both;
  z-index: 3;
}
.avatar-emoji {
  font-size: 40rpx;
  position: relative;
  z-index: 2;
}
.avatar-glow {
  position: absolute;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(239, 68, 68, 0.4) 0%, transparent 70%);
  animation: pulseGlow 2s ease-in-out infinite;
}
.avatar-running .avatar-emoji {
  animation: wiggle 0.6s ease-in-out infinite;
}

