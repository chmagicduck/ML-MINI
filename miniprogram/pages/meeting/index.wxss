.avatar-pos-12 { top: 170rpx; left: 24rpx; }
.avatar-pos-13 { top: 80rpx; left: 24rpx; }
/* 第二圈-上 */
.avatar-pos-14 { top: 60rpx; left: 150rpx; }
.avatar-pos-15 { top: 60rpx; left: 250rpx; }
.avatar-pos-16 { top: 60rpx; left: 350rpx; }
/* 第二圈-右 */
.avatar-pos-17 { top: 130rpx; right: 70rpx; }
.avatar-pos-18 { top: 220rpx; right: 70rpx; }
/* 第二圈-下 */
.avatar-pos-19 { bottom: 60rpx; left: 350rpx; }
.avatar-pos-20 { bottom: 60rpx; left: 250rpx; }
.avatar-pos-21 { bottom: 60rpx; left: 150rpx; }
/* 第二圈-左 */
.avatar-pos-22 { top: 220rpx; left: 70rpx; }
.avatar-pos-23 { top: 130rpx; left: 70rpx; }
/* 第三圈（24-35） */
.avatar-pos-24 { top: 30rpx; left: 150rpx; }
.avatar-pos-25 { top: 30rpx; left: 260rpx; }
.avatar-pos-26 { top: 30rpx; left: 370rpx; }
.avatar-pos-27 { top: 110rpx; right: 46rpx; }
.avatar-pos-28 { top: 200rpx; right: 46rpx; }
.avatar-pos-29 { top: 290rpx; right: 46rpx; }
.avatar-pos-30 { bottom: 30rpx; left: 370rpx; }
.avatar-pos-31 { bottom: 30rpx; left: 260rpx; }
.avatar-pos-32 { bottom: 30rpx; left: 150rpx; }
.avatar-pos-33 { top: 290rpx; left: 46rpx; }
.avatar-pos-34 { top: 200rpx; left: 46rpx; }
.avatar-pos-35 { top: 110rpx; left: 46rpx; }
/* 第四圈（36-49） */
.avatar-pos-36 { top: 10rpx; left: 55rpx; }
.avatar-pos-37 { top: 10rpx; left: 170rpx; }
