.avatar-pos-5 { top: 170rpx; right: 24rpx; }
.avatar-pos-6 { top: 260rpx; right: 24rpx; }
/* 下排 */
.avatar-pos-7 { bottom: 20rpx; left: 400rpx; }
.avatar-pos-8 { bottom: 20rpx; left: 300rpx; }
.avatar-pos-9 { bottom: 20rpx; left: 200rpx; }
.avatar-pos-10 { bottom: 20rpx; left: 100rpx; }
/* 左侧 */
