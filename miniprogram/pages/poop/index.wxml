<!--pages/poop/index.wxml — 带薪拉粑粑（VIP厕位版）-->
<view class="page">

  <!-- 顶部计时器 + 收益 -->
  <view class="timer-header">
    <text class="timer-big">{{sessionTimeStr}}</text>
    <text class="session-earn">本次收益 {{sessionEarnings}}</text>
  </view>

  <!-- VIP厕位可视化区域 -->
  <view class="vip-booth">
    <!-- 瓷砖墙背景（通过 CSS 实现） -->
    <view class="tile-wall"></view>

    <!-- 隔间内部 -->
    <view class="booth-interior">
      <!-- 马桶 -->
      <view class="toilet">
        <view class="toilet-lid"></view>
        <view class="toilet-bowl"></view>
      </view>

      <!-- 用户角色 -->
      <text class="user-avatar {{isRunning ? 'avatar-active' : 'avatar-idle'}}">{{isRunning ? '🧘‍♂️' : '👤'}}</text>

      <!-- 产出特效（运行时显示） -->
      <view class="effects-layer" wx:if="{{isRunning}}">
        <text class="poop-bounce">💩</text>
        <view class="gold-particles">
          <text class="gold-coin g1">¥</text>
          <text class="gold-coin g2">¥</text>
          <text class="gold-coin g3">¥</text>
        </view>
      </view>
    </view>

    <!-- 门（关键动画） -->
    <view class="door {{doorOpen ? 'door-open' : 'door-closed'}}">
      <view class="door-handle"></view>
      <view class="door-label">
        <text class="door-label-text">{{doorOpen ? 'OCCUPIED' : 'VACANT'}}</text>
      </view>
    </view>

    <!-- 底部水流装饰 -->
    <view class="water-flow">
      <view class="water-wave w1"></view>
      <view class="water-wave w2"></view>
    </view>
  </view>

  <!-- 鼓励语 -->
  <text class="encouragement">{{encouragement}}</text>

  <!-- 操作按钮区 -->
  <view class="action-row">
    <view class="btn-toggle {{isRunning ? 'btn-stop' : 'btn-start'}}" bindtap="onToggle">
      <text class="btn-text">{{isRunning ? '🚿 冲水下班' : '🚽 开始蹲坑'}}</text>
    </view>
  </view>

  <!-- 快捷操作 -->
  <view class="quick-actions">
    <view class="quick-btn" bindtap="onShowManualInput">
      <text class="quick-btn-icon">📝</text>
      <text class="quick-btn-label">快速记录</text>
    </view>
    <view class="quick-btn" bindtap="onGoHistory">
      <text class="quick-btn-icon">📋</text>
      <text class="quick-btn-label">蹲坑记录</text>
    </view>
  </view>

  <!-- 手动记录输入区 -->
  <view class="manual-panel {{showManualInput ? 'panel-show' : 'panel-hide'}}">
    <view class="manual-mask" wx:if="{{showManualInput}}" bindtap="onHideManualInput"></view>
    <view class="manual-card" wx:if="{{showManualInput}}">
      <text class="manual-title">快速记录蹲坑</text>
      <view class="manual-input-row">
        <input class="manual-input"
               type="digit"
               placeholder="输入分钟数"
               value="{{manualMinutes}}"
               bindinput="onManualMinutesInput" />
        <text class="manual-unit">分钟</text>
      </view>
      <view class="manual-preview">
        <text class="manual-preview-label">预计收益</text>
        <text class="manual-preview-value">{{manualPreviewEarnings}}</text>
      </view>
      <view class="manual-btn-row">
        <view class="manual-btn-cancel" bindtap="onHideManualInput">
          <text class="manual-btn-text">取消</text>
        </view>
        <view class="manual-btn-confirm" bindtap="onConfirmManual">
          <text class="manual-btn-text-primary">确认记录</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 今日统计 -->
  <view class="stats-section">
    <text class="stats-title">今日战绩</text>
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-value">{{todayEarnings}}</text>
        <text class="stat-label">今日收益</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{todaySeconds}}s</text>
        <text class="stat-label">今日蹲坑</text>
      </view>
    </view>
  </view>

  <!-- 历史统计 -->
  <view class="stats-section">
    <text class="stats-title">历史总览</text>
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-value">{{totalEarnings}}</text>
        <text class="stat-label">累计收益</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{sessionCount}}</text>
        <text class="stat-label">累计次数</text>
      </view>
    </view>
  </view>

  <!-- 温馨提示 -->
  <view class="tips-card">
    <text class="tips-text">带薪拉粑粑是打工人神圣权利，请合理行使</text>
  </view>

  <view class="safe-bottom"></view>
</view>
