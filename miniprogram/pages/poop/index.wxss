/* pages/poop/index.wxss — 带薪拉粑粑（VIP厕位版） */
.page {
  min-height: 100vh;
  background: #F8FAFC;
  padding: 0 32rpx 80rpx;
}

/* ===== 顶部计时器 ===== */
.timer-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 16rpx;
}

.timer-big {
  font-size: 80rpx;
  font-weight: 700;
  color: #1E40AF;
  letter-spacing: 4rpx;
  font-variant-numeric: tabular-nums;
}

.session-earn {
  font-size: 32rpx;
  color: #2563EB;
  font-weight: 600;
  margin-top: 8rpx;
}

/* ===== VIP厕位可视化 ===== */
.vip-booth {
  position: relative;
  background: #F1F5F9;
  border-radius: 80rpx;
  margin: 24rpx 40rpx;
  height: 480rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}

/* 瓷砖墙背景 */
.tile-wall {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: radial-gradient(circle, #94A3B8 1rpx, transparent 1rpx);
  background-size: 24rpx 24rpx;
  opacity: 0.1;
  z-index: 0;
}

/* 隔间内部 */
.booth-interior {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  bottom: 60rpx;
  width: 320rpx;
  height: 320rpx;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

/* 马桶视觉 */
.toilet {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 20rpx;
}

.toilet-lid {
  width: 80rpx;
  height: 24rpx;
  background: #CBD5E1;
  border-radius: 8rpx 8rpx 0 0;
}

.toilet-bowl {
  width: 100rpx;
  height: 60rpx;
  background: #E2E8F0;
  border-radius: 0 0 50rpx 50rpx;
}

/* 用户角色 */
.user-avatar {
  font-size: 64rpx;
  margin-top: 12rpx;
  display: block;
  transition: all 0.3s ease;
}

.avatar-active {
  transform: scale(1.1);
}

.avatar-idle {
  opacity: 0.4;
  filter: grayscale(1);
}

/* 产出特效 */
.effects-layer {
  position: absolute;
  top: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 2;
}

.poop-bounce {
  font-size: 48rpx;
  animation: wiggle 0.6s ease-in-out infinite;
}

.gold-particles {
  position: absolute;
  top: -20rpx;
  display: flex;
  gap: 16rpx;
}

.gold-coin {
  font-size: 28rpx;
  font-weight: 700;
  color: #F59E0B;
  animation: floatGold 1.8s ease-out infinite;
}

.g1 { animation-delay: 0s; }
.g2 { animation-delay: 0.6s; }
.g3 { animation-delay: 1.2s; }

/* 门 */
.door {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  bottom: 60rpx;
  width: 320rpx;
  height: 320rpx;
  background: #3B82F6;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 3;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  transform-origin: left center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.door-closed {
  transform: translateX(-50%) translateX(0);
}

.door-open {
  transform: translateX(-50%) translateX(-90%);
}

.door-handle {
  width: 8rpx;
  height: 48rpx;
  background: #93C5FD;
  border-radius: 4rpx;
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
}

.door-label {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 8rpx;
  padding: 8rpx 24rpx;
}

.door-label-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 4rpx;
}

/* 底部水流装饰 */
.water-flow {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60rpx;
  overflow: hidden;
  z-index: 4;
}

.water-wave {
  position: absolute;
  bottom: 0;
  left: -10%;
  width: 120%;
  height: 40rpx;
  background: linear-gradient(90deg, #93C5FD, #60A5FA, #93C5FD);
  border-radius: 50% 50% 0 0;
  opacity: 0.3;
  animation: waterFlow 2s ease-in-out infinite alternate;
}

.w1 {
  animation-delay: 0s;
}

.w2 {
  opacity: 0.2;
  height: 30rpx;
  animation-delay: 1s;
}

/* ===== 鼓励语 ===== */
.encouragement {
  font-size: 26rpx;
  color: #757575;
  text-align: center;
  display: block;
  margin: 16rpx 0 24rpx;
  font-style: italic;
  min-height: 40rpx;
}

/* ===== 操作按钮 ===== */
.action-row {
  padding: 0 16rpx;
  margin-bottom: 24rpx;
}

.btn-toggle {
  width: 100%;
  border-radius: 48rpx;
  padding: 28rpx 0;
  text-align: center;
}

.btn-start {
  background: linear-gradient(135deg, #60A5FA, #2563EB);
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.35);
}

.btn-stop {
  background: linear-gradient(135deg, #EF9A9A, #E57373);
  box-shadow: 0 8rpx 24rpx rgba(239, 83, 80, 0.3);
}

.btn-toggle:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

/* ===== 快捷操作 ===== */
.quick-actions {
  display: flex;
  gap: 24rpx;
  padding: 0 16rpx;
  margin-bottom: 24rpx;
}

.quick-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.quick-btn:active {
  opacity: 0.7;
  transform: scale(0.97);
}

.quick-btn-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.quick-btn-label {
  font-size: 24rpx;
  color: #64748B;
  font-weight: 500;
}

/* ===== 手动记录面板 ===== */
.manual-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.panel-hide {
  pointer-events: none;
}

.manual-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 100;
}

.manual-card {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 40rpx calc(40rpx + env(safe-area-inset-bottom));
  z-index: 101;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.manual-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1E293B;
  display: block;
  margin-bottom: 32rpx;
  text-align: center;
}

.manual-input-row {
  display: flex;
  align-items: center;
  background: #F1F5F9;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
}

.manual-input {
  flex: 1;
  font-size: 36rpx;
  font-weight: 600;
  color: #1E293B;
}

.manual-unit {
  font-size: 28rpx;
  color: #94A3B8;
  margin-left: 12rpx;
}

.manual-preview {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 8rpx;
  margin-bottom: 32rpx;
}

.manual-preview-label {
  font-size: 26rpx;
  color: #94A3B8;
}

.manual-preview-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #2563EB;
}

.manual-btn-row {
  display: flex;
  gap: 20rpx;
}

.manual-btn-cancel {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 16rpx;
  background: #F1F5F9;
}

.manual-btn-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #64748B;
}

.manual-btn-confirm {
  flex: 2;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #60A5FA, #2563EB);
}

.manual-btn-confirm:active {
  opacity: 0.85;
}

.manual-btn-text-primary {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* ===== 统计卡片 ===== */
.stats-section {
  margin-bottom: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.stats-title {
  font-size: 24rpx;
  color: #9E9E9E;
  display: block;
  margin-bottom: 20rpx;
}

.stats-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #1E40AF;
  display: block;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #9E9E9E;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #F0F0F0;
}

/* ===== 提示 ===== */
.tips-card {
  margin-bottom: 24rpx;
  background: #FFF8E1;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.tips-text {
  font-size: 24rpx;
  color: #F57F17;
  display: block;
  text-align: center;
}

.safe-bottom {
  height: 80rpx;
}

/* ===== Animations ===== */
@keyframes floatGold {
  0% {
    transform: translateY(0) scale(1);
    opacity: 0;
  }
  20% {
    opacity: 1;
  }
  100% {
    transform: translateY(-80rpx) scale(0.8);
    opacity: 0;
  }
}

@keyframes wiggle {
  0%, 100% {
    transform: rotate(-8deg);
  }
  50% {
    transform: rotate(8deg);
  }
}

@keyframes waterFlow {
  0% {
    transform: translateY(0);
  }
  100% {
    transform: translateY(20rpx);
  }
}

@keyframes breathe {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.5;
  }
}
