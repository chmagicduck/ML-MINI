<!--pages/profile/index.wxml — 个人基地-->
<view class="page">

  <!-- 1. 顶部个人资料区 -->
  <view class="profile-header">
    <view class="avatar-wrap">
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image wx:if="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill" />
        <view wx:else class="avatar-circle">
          <text class="avatar-placeholder">👤</text>
        </view>
      </button>
      <view class="avatar-online"></view>
    </view>
    <view class="profile-info">
      <input type="nickname" class="profile-name-input" value="{{nickname}}" placeholder="点击设置昵称" bindchange="onNicknameChange" />
      <text class="profile-sub">摸鱼天数: {{moyuDays}}天 · 已同步</text>
    </view>
    <text class="profile-arrow">›</text>
  </view>

  <!-- 2. 收益核心卡片 -->
  <view class="earnings-card">
    <view class="earnings-deco"></view>
    <view class="earnings-top">
      <view class="earnings-left">
        <text class="earnings-label">累计摸鱼总收益</text>
        <text class="earnings-value">{{totalMoney}}</text>
      </view>
      <view class="earnings-badge">
        <text class="badge-emoji">{{levelEmoji}}</text>
        <text class="badge-name">{{levelName}}</text>
      </view>
    </view>
    <view class="earnings-progress-wrap">
      <view class="earnings-progress-top">
        <text class="earnings-progress-label">等级提升进度</text>
        <text class="earnings-progress-hint" wx:if="{{!isMaxLevel}}">
          再赚 <text class="earnings-progress-amount">¥{{diffToNext}}</text> 升级
        </text>
        <text class="earnings-progress-hint" wx:else>已满级 🎉</text>
      </view>
      <view class="earnings-bar-bg">
        <view class="earnings-bar-fill" style="width: {{levelProgress}}%">
          <view class="earnings-bar-glow"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 3. 摸鱼之路 -->
  <view class="roadmap-card">
    <view class="roadmap-header">
      <view class="roadmap-title-wrap">
        <text class="roadmap-icon">📍</text>
        <text class="roadmap-title"> 摸鱼之路</text>
      </view>
      <text class="roadmap-max">最高等级: 传说打工人</text>
    </view>
    <view class="roadmap-body">
      <!-- 背景线 -->
      <view class="roadmap-bg-line"></view>
      <!-- 激活线 -->
      <view class="roadmap-active-line" style="width: {{roadmapActiveWidth}}"></view>
      <!-- 节点 -->
      <scroll-view scroll-x class="roadmap-scroll" enhanced show-scrollbar="{{false}}">
        <view class="roadmap-nodes">
          <view class="roadmap-node" wx:for="{{roadmapNodes}}" wx:key="name">
            <view class="node-circle {{item.isReached ? 'node-reached' : 'node-locked'}}">
              <text class="node-icon" wx:if="{{item.isReached}}">{{item.emoji}}</text>
              <text class="node-lock" wx:else>🔒</text>
            </view>
            <text class="node-name {{item.isReached ? 'name-reached' : 'name-locked'}}">{{item.shortName}}</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 4. 设置列表组1: 薪资工时 + 节假日 -->
  <view class="settings-group">
    <view class="setting-item" bindtap="onGoToBasic">
      <view class="setting-icon-wrap">
        <text class="setting-icon">⚙️</text>
      </view>
      <text class="setting-label">薪资工时</text>
      <text class="setting-arrow">›</text>
    </view>
    <view class="setting-divider"></view>
    <view class="setting-item" bindtap="onGoToCalendar">
      <view class="setting-icon-wrap">
        <text class="setting-icon">📅</text>
      </view>
      <text class="setting-label">节假日</text>
      <text class="setting-arrow">›</text>
    </view>
  </view>

  <!-- 6. 设置列表组2: 时钟样式 -->
  <view class="settings-group">
    <view class="setting-item">
      <view class="setting-icon-wrap">
        <text class="setting-icon">🕐</text>
      </view>
      <text class="setting-label">时钟样式</text>
      <view class="setting-right">
        <text class="setting-value">拟物</text>
        <text class="setting-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 7. 设置列表组3: 关于 + 数据管理 -->
  <view class="settings-group settings-group-last">
    <view class="setting-item">
      <view class="setting-icon-wrap">
        <text class="setting-icon">ℹ️</text>
      </view>
      <text class="setting-label">关于软件</text>
      <text class="setting-arrow">›</text>
    </view>
    <view class="setting-divider"></view>
    <view class="setting-item" bindtap="onGoToDataManage">
      <view class="setting-icon-wrap">
        <text class="setting-icon">📦</text>
      </view>
      <text class="setting-label">数据管理</text>
      <text class="setting-arrow">›</text>
    </view>
  </view>

  <!-- 页脚 -->
  <view class="footer">
    <text class="footer-text">薪潮涌动 · 个人基地 v2.5.0</text>
  </view>

  <view class="safe-bottom"></view>
</view>
