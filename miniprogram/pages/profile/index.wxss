/* pages/profile/index.wxss — 个人基地 */

.page {
  min-height: 100vh;
  background: #F8FAFC;
  display: flex;
  flex-direction: column;
  padding: 16rpx 32rpx 0;
}

/* ===== 个人资料区 ===== */
.profile-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 8rpx 8rpx 24rpx;
}
.avatar-wrap {
  position: relative;
  flex-shrink: 0;
  width: 96rpx;
  height: 96rpx;
}
.avatar-circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #E2E8F0;
  border: 3rpx solid #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.avatar-placeholder { font-size: 48rpx; }
/* 头像按钮 & 图片 */
.avatar-btn {
  display: block;
  width: 96rpx !important;
  height: 96rpx !important;
  min-height: 0 !important;
  padding: 0 !important;
  margin: 0 !important;
  border: none !important;
  background: transparent !important;
  line-height: 1;
  overflow: hidden;
  border-radius: 50%;
  box-sizing: border-box;
}
.avatar-btn::after { border: none; }
.avatar-img {
  display: block;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 3rpx solid #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}
/* 昵称输入框 */
.profile-name-input {
  font-size: 30rpx;
  font-weight: 800;
  color: #1E293B;
  line-height: 1;
  height: 48rpx;
  min-height: 0;
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
}
.avatar-online {
  position: absolute;
  bottom: -2rpx;
  right: -2rpx;
  width: 28rpx;
  height: 28rpx;
  background: #22C55E;
  border: 3rpx solid #FFFFFF;
  border-radius: 50%;
}
.profile-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.profile-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #1E293B;
  line-height: 1;
  display: block;
}
.profile-sub {
  font-size: 20rpx;
  color: #94A3B8;
  font-weight: 700;
  margin-top: 8rpx;
  display: block;
}
.profile-arrow {
  font-size: 28rpx;
  color: #CBD5E1;
}

/* ===== 收益核心卡片 ===== */
.earnings-card {
  background: linear-gradient(135deg, #1E3A8A, #2563EB);
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(37, 99, 235, 0.2);
  position: relative;
  overflow: hidden;
  margin-bottom: 24rpx;
}
.earnings-deco {
  position: absolute;
  top: 0; right: 0;
  width: 256rpx; height: 256rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 50%;
  filter: blur(40rpx);
  transform: translate(33%, -50%);
}
.earnings-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}
.earnings-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.earnings-label {
  font-size: 18rpx;
  color: #93C5FD;
  font-weight: 700;
  opacity: 0.8;
  display: block;
}
.earnings-value {
  font-size: 48rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1;
  display: block;
}
.earnings-badge {
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(10rpx);
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}
.badge-emoji { font-size: 26rpx; }
.badge-name {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: 700;
}

.earnings-progress-wrap {
  position: relative;
  z-index: 1;
  background: rgba(0,0,0,0.1);
  border-radius: 20rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(255,255,255,0.05);
}
.earnings-progress-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 8rpx;
}
.earnings-progress-label {
  font-size: 18rpx;
  color: #93C5FD;
  font-weight: 700;
  opacity: 0.7;
}
.earnings-progress-hint {
  font-size: 18rpx;
  color: #FFFFFF;
  font-weight: 700;
}
.earnings-progress-amount {
  color: #FDE68A;
}
.earnings-bar-bg {
  height: 12rpx;
  width: 100%;
  background: rgba(0,0,0,0.3);
  border-radius: 12rpx;
  overflow: hidden;
}
.earnings-bar-fill {
  height: 100%;
  background: linear-gradient(to right, #67E8F9, #60A5FA);
  border-radius: 12rpx;
  position: relative;
  transition: width 0.5s ease;
}
.earnings-bar-glow {
  position: absolute;
  right: 0; top: 0; bottom: 0;
  width: 32rpx;
  background: rgba(255,255,255,0.4);
  filter: blur(4rpx);
}

/* ===== 摸鱼之路 ===== */
.roadmap-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 24rpx;
  border: 1rpx solid #F1F5F9;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  margin-bottom: 24rpx;
}
.roadmap-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}
.roadmap-title-wrap {
  display: flex;
  align-items: center;
  gap: 4rpx;
}
.roadmap-icon { font-size: 24rpx; }
.roadmap-title {
  font-size: 22rpx;
  font-weight: 800;
  color: #334155;
}
.roadmap-max {
  font-size: 18rpx;
  color: #94A3B8;
  font-weight: 700;
}

.roadmap-body {
  position: relative;
  padding: 0 16rpx 8rpx;
}
.roadmap-bg-line {
  position: absolute;
  top: 26rpx;
  left: 32rpx; right: 32rpx;
  height: 4rpx;
  background: #F1F5F9;
}
.roadmap-active-line {
  position: absolute;
  top: 26rpx;
  left: 32rpx;
  height: 4rpx;
  background: #3B82F6;
  transition: width 0.5s ease;
}

.roadmap-scroll {
  width: 100%;
  white-space: nowrap;
}
.roadmap-nodes {
  display: flex;
  justify-content: space-between;
  position: relative;
  z-index: 1;
  min-width: 100%;
}
.roadmap-node {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  width: 64rpx;
}
.node-circle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  transition: all 0.3s;
}
.node-reached {
  background: #EFF6FF;
  border: 3rpx solid #3B82F6;
}
.node-locked {
  background: #F8FAFC;
  border: 3rpx solid #F1F5F9;
  opacity: 0.4;
  filter: grayscale(1);
}
.node-icon { font-size: 28rpx; }
.node-lock { font-size: 20rpx; }
.node-name {
  font-size: 16rpx;
  margin-top: 4rpx;
  font-weight: 800;
  text-align: center;
}
.name-reached { color: #2563EB; }
.name-locked { color: #94A3B8; }

/* ===== 统计面板 ===== */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.stat-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 20rpx;
  border: 1rpx solid #F1F5F9;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.stat-icon-wrap {
  width: 56rpx; height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.stat-icon-blue { background: #EFF6FF; }
.stat-icon-orange { background: #FFF7ED; }
.stat-icon-text { font-size: 24rpx; }
.stat-content {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.stat-label {
  font-size: 18rpx;
  font-weight: 700;
  color: #94A3B8;
  display: block;
}
.stat-value {
  font-size: 26rpx;
  font-weight: 800;
  color: #334155;
  display: block;
}

/* ===== 设置列表 ===== */
.settings-group {
  background: #FFFFFF;
  border-radius: 32rpx;
  border: 1rpx solid #F1F5F9;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  overflow: hidden;
  margin-bottom: 16rpx;
}
.settings-group-last { margin-bottom: 16rpx; }

.setting-item {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx;
  gap: 24rpx;
}
.setting-item:active { background: #F8FAFC; }

.setting-icon-wrap {
  width: 56rpx; height: 56rpx;
  border-radius: 16rpx;
  background: #F8FAFC;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.setting-icon-danger { background: #FEF2F2; }
.setting-icon { font-size: 28rpx; }
.setting-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #334155;
  flex: 1;
}
.setting-label-danger { color: #EF4444; }
.setting-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.setting-value {
  font-size: 22rpx;
  font-weight: 700;
  color: #94A3B8;
}
.setting-arrow {
  font-size: 28rpx;
  color: #CBD5E1;
}
.setting-divider {
  height: 1rpx;
  background: #F8FAFC;
  margin: 0 80rpx;
}

.setting-danger:active { background: #FEF2F2; }

/* ===== 页脚 ===== */
.footer {
  padding: 32rpx 0;
  display: flex;
  justify-content: center;
}
.footer-text {
  font-size: 18rpx;
  color: #CBD5E1;
  font-weight: 700;
  letter-spacing: 2rpx;
}

/* ===== 底部安全区 ===== */
.safe-bottom { height: 120rpx; }
