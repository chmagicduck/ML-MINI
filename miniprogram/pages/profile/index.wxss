/* pages/profile/index.wxss — 我的页 V2 */

.page {
  min-height: 100vh;
  background: #F0F4F0;
  display: flex;
  flex-direction: column;
}

/* ===== 头部用户卡片 ===== */
.header-card {
  background: linear-gradient(135deg, #2E7D32, #43A047);
  padding: 48rpx 32rpx 40rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 28rpx;
}
.header-emoji {
  font-size: 100rpx;
}
.header-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  display: block;
}
.header-salary {
  font-size: 28rpx;
  color: #A5D6A7;
  display: block;
}

/* ===== 分区 ===== */
.section {
  margin: 24rpx 32rpx 0;
}
.section-title {
  font-size: 24rpx;
  color: #9E9E9E;
  display: block;
  margin-bottom: 12rpx;
  padding-left: 4rpx;
}

/* ===== 单元格组 ===== */
.cell-group {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.07);
}
.cell {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
}
.cell:active { background: #F5F5F5; }
.cell-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}
.cell-icon {
  font-size: 44rpx;
  flex-shrink: 0;
}
.cell-title {
  font-size: 30rpx;
  color: #333;
  display: block;
  font-weight: 500;
}
.cell-sub {
  font-size: 22rpx;
  color: #9E9E9E;
  display: block;
  margin-top: 4rpx;
}
.cell-arrow {
  font-size: 36rpx;
  color: #C0C0C0;
  margin-left: 16rpx;
}
.cell-divider {
  height: 1rpx;
  background: #F5F5F5;
  margin: 0 24rpx;
}

/* ===== 页脚 ===== */
.footer {
  margin-top: auto;
  padding: 48rpx 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.footer-slogan {
  font-size: 24rpx;
  color: #9E9E9E;
  text-align: center;
  font-style: italic;
  display: block;
}
.footer-version {
  font-size: 22rpx;
  color: #BDBDBD;
  display: block;
}

/* ===== 底部安全区 ===== */
.safe-bottom { height: 120rpx; }

/* ===== V1.0.1 皮肤系统 ===== */
.skins-container {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 12rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.07);
}

.skin-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  border: 2rpx solid #E0E0E0;
  position: relative;
  transition: all 0.3s ease;
}

.skin-item:active {
  transform: scale(0.95);
  background: #F5F5F5;
}

.skin-item-active {
  border-color: #4CAF50;
  background: #F1F8F6;
  box-shadow: 0 0 16rpx rgba(76,175,80,0.2);
}

.skin-image {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #EEEEEE;
}

.skin-name {
  font-size: 20rpx;
  color: #333;
  font-weight: 500;
  text-align: center;
}

.skin-badge {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #4CAF50;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
}

.skins-tip {
  font-size: 22rpx;
  color: #9E9E9E;
  display: block;
  margin-top: 12rpx;
  text-align: center;
}
