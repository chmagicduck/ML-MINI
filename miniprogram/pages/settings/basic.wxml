<!--pages/settings/basic.wxml — 基本设置表单-->
<!-- 变更：移除晚休/加班间隙，移除入职日期 -->
<scroll-view scroll-y class="page">

  <!-- ===== 薪资配置 ===== -->
  <view class="form-section">
    <text class="section-title">💰 薪资配置</text>
    <view class="form-group">

      <view class="form-item">
        <text class="form-label">月薪（税前）</text>
        <view class="input-row">
          <text class="input-prefix">¥</text>
          <input
            class="form-input"
            type="digit"
            placeholder="请输入月薪"
            placeholder-class="placeholder"
            value="{{settings.monthlySalary > 0 ? settings.monthlySalary : ''}}"
            bindinput="onSalaryInput"
          />
        </view>
      </view>

      <view class="form-divider"></view>

      <view class="form-item">
        <text class="form-label">发薪日</text>
        <picker range="{{payDays}}" value="{{payDayIndex}}" bindchange="onPayDayChange">
          <view class="picker-value">
            <text>每月 {{payDays[payDayIndex]}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

    </view>
  </view>

  <!-- ===== 工时配置 ===== -->
  <view class="form-section">
    <text class="section-title">⏰ 工时配置</text>
    <view class="form-group">

      <view class="form-item">
        <text class="form-label">上班时间</text>
        <picker range="{{timeOptions}}" value="{{workStartIndex}}" bindchange="onWorkStartChange">
          <view class="picker-value">
            <text>{{timeOptions[workStartIndex]}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <view class="form-divider"></view>

      <view class="form-item">
        <text class="form-label">下班时间</text>
        <picker range="{{timeOptions}}" value="{{workEndIndex}}" bindchange="onWorkEndChange">
          <view class="picker-value">
            <text>{{timeOptions[workEndIndex]}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <view class="form-divider"></view>

      <view class="form-item">
        <text class="form-label">午休</text>
        <switch checked="{{settings.lunchBreakEnabled}}" color="#3B82F6" bindchange="onLunchBreakToggle" />
      </view>

      <block wx:if="{{settings.lunchBreakEnabled}}">
        <view class="form-divider"></view>
        <view class="form-item form-item-indent">
          <text class="form-label">午休开始</text>
          <picker range="{{timeOptions}}" value="{{lunchStartIndex}}" bindchange="onLunchStartChange">
            <view class="picker-value">
              <text>{{timeOptions[lunchStartIndex]}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>
        <view class="form-divider"></view>
        <view class="form-item form-item-indent">
          <text class="form-label">午休结束</text>
          <picker range="{{timeOptions}}" value="{{lunchEndIndex}}" bindchange="onLunchEndChange">
            <view class="picker-value">
              <text>{{timeOptions[lunchEndIndex]}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>
      </block>

    </view>
  </view>

  <!-- ===== 工作日模式 ===== -->
  <view class="form-section">
    <text class="section-title">📅 工作日模式</text>
    <view class="form-group">
      <radio-group bindchange="onWorkdayModeChange">
        <view
          wx:for="{{workdayModes}}"
          wx:key="key"
          class="radio-item {{item.key === settings.workdayMode ? 'radio-item-active' : ''}}"
        >
          <radio value="{{item.key}}" checked="{{item.key === settings.workdayMode}}" color="#3B82F6" />
          <view class="radio-info">
            <text class="radio-label">{{item.label}}</text>
            <text class="radio-desc">{{item.desc}}</text>
          </view>
        </view>
      </radio-group>
    </view>
  </view>

  <!-- ===== 保存按钮 ===== -->
  <view class="save-wrap">
    <button class="save-btn" bindtap="onSave">💾 保存设置</button>
  </view>

  <view class="safe-bottom"></view>
</scroll-view>
