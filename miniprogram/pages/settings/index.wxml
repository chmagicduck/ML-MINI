<!--pages/settings/index.wxml — 设置列表-->
<view class="page">
  <!-- 头部卡片 -->
  <view class="header-card">
    <text class="header-emoji">🐒</text>
    <view>
      <text class="header-title">吗喽薪事</text>
      <text class="header-sub">只要我不努力，老板就永远过不上想要的生活</text>
    </view>
  </view>

  <!-- 设置列表 -->
  <view class="section">
    <text class="section-title">基础配置</text>

    <view class="cell-group">
      <!-- 基本设置 -->
      <view class="cell" bindtap="onGoToBasic">
        <view class="cell-left">
          <text class="cell-icon">💼</text>
          <view>
            <text class="cell-title">薪资与工时</text>
            <text class="cell-sub">月薪、上下班时间、工作日</text>
          </view>
        </view>
        <text class="cell-arrow">›</text>
      </view>

      <view class="cell-divider"></view>

      <!-- 重要日期（跳转 basic 页统一配置） -->
      <view class="cell" bindtap="onGoToBasic">
        <view class="cell-left">
          <text class="cell-icon">📆</text>
          <view>
            <text class="cell-title">重要日期</text>
            <text class="cell-sub">入职日、退休日</text>
          </view>
        </view>
        <text class="cell-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="section">
    <text class="section-title">特效与体验</text>
    <view class="cell-group">
      <!-- 金币音效 -->
      <view class="cell">
        <view class="cell-left">
          <text class="cell-icon">🔔</text>
          <view>
            <text class="cell-title">金币掉落音效</text>
            <text class="cell-sub">开启摸鱼时播放音效</text>
          </view>
        </view>
        <switch checked="{{soundEnabled}}" color="#4CAF50" bindchange="onToggleSound" />
      </view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="footer">
    <text class="footer-text">吗喽薪事 v1.0.0</text>
    <text class="footer-text">老板走开，摸鱼自由</text>
  </view>
</view>
