/* pages/settings/index.wxss */
.page {
  min-height: 100vh;
  background: #F0F4F0;
  padding-bottom: 80rpx;
}

/* ===== 头部卡片 ===== */
.header-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  padding: 40rpx 32rpx;
  gap: 24rpx;
}
.header-emoji {
  font-size: 80rpx;
  flex-shrink: 0;
}
.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1B5E20;
  display: block;
  margin-bottom: 6rpx;
}
.header-sub {
  font-size: 22rpx;
  color: #4CAF50;
  display: block;
  font-style: italic;
}

/* ===== 分组标题 ===== */
.section {
  margin: 24rpx 32rpx 0;
}
.section-title {
  font-size: 24rpx;
  color: #9E9E9E;
  display: block;
  margin-bottom: 12rpx;
  padding-left: 4rpx;
}

/* ===== 列表组 ===== */
.cell-group {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}
.cell {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx;
  background: #fff;
  position: relative;
}
.cell:active {
  background: #F5F5F5;
}
.cell-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}
.cell-icon {
  font-size: 44rpx;
  flex-shrink: 0;
}
.cell-title {
  font-size: 30rpx;
  color: #333;
  display: block;
  margin-bottom: 4rpx;
}
.cell-sub {
  font-size: 22rpx;
  color: #9E9E9E;
  display: block;
}
.cell-arrow {
  font-size: 40rpx;
  color: #C8C8C8;
  font-weight: 300;
}
.cell-divider {
  height: 1rpx;
  background: #F0F0F0;
  margin: 0 28rpx;
}

/* ===== 底部 ===== */
.footer {
  margin-top: 60rpx;
  text-align: center;
}
.footer-text {
  display: block;
  font-size: 22rpx;
  color: #BDBDBD;
  margin-bottom: 8rpx;
}
