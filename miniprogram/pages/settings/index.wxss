.page{min-height:100vh;background:var(--deep-bg);padding:30rpx}
.hero{padding:28rpx;border-radius:24rpx;box-shadow:var(--deep-shadow);margin-bottom:18rpx}
.title{display:block;font-size:40rpx;color:var(--deep-primary);font-weight:700}.sub{color:var(--deep-text-secondary);font-size:24rpx}
.cell{display:flex;justify-content:space-between;padding:28rpx;margin-bottom:16rpx;border-radius:20rpx;box-shadow:var(--deep-shadow);color:var(--deep-text-primary)}
