<!--pages/stats/index.wxml — 洋流情报-->
<view class="page">

  <!-- 维度切换 tab -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'day' ? 'tab-active' : ''}}" bindtap="onSwitchTab" data-tab="day">
      <text>当日</text>
    </view>
    <view class="tab-item {{activeTab === 'week' ? 'tab-active' : ''}}" bindtap="onSwitchTab" data-tab="week">
      <text>本周</text>
    </view>
    <view class="tab-item {{activeTab === 'month' ? 'tab-active' : ''}}" bindtap="onSwitchTab" data-tab="month">
      <text>本月</text>
    </view>
    <view class="tab-item {{activeTab === 'year' ? 'tab-active' : ''}}" bindtap="onSwitchTab" data-tab="year">
      <text>全年进度</text>
    </view>
  </view>

  <!-- 核心看板卡片 -->
  <view class="chart-card">
    <!-- CSS 甜甜圈图 -->
    <view class="donut-wrap">
      <view class="donut-ring" style="{{donutStyle}}"></view>
      <view class="donut-hole"></view>
      <view class="donut-center">
        <text class="center-label">{{centerLabel}}</text>
        <text class="center-rate">{{moyuRate}}</text>
      </view>
    </view>

    <!-- 数据图例列表 -->
    <view class="legend-list">
      <!-- 工作时间 -->
      <view class="legend-item legend-bg-gray">
        <view class="legend-left">
          <view class="legend-dot dot-gray"></view>
          <text class="legend-name">工作时间</text>
        </view>
        <view class="legend-right">
          <text class="legend-value">{{workTime}}</text>
          <text class="legend-pct">{{workPercent}}</text>
        </view>
      </view>

      <!-- 摸鱼时间 -->
      <view class="legend-item legend-bg-blue">
        <view class="legend-left">
          <view class="legend-dot dot-blue"></view>
          <text class="legend-name legend-name-blue">摸鱼时间</text>
        </view>
        <view class="legend-right">
          <text class="legend-value legend-value-blue">{{moyuTime}}</text>
          <text class="legend-pct legend-pct-blue">{{moyuPercent}}</text>
        </view>
      </view>

      <!-- 尚未过去 -->
      <view class="legend-item legend-bg-future" wx:if="{{hasFuture}}">
        <view class="legend-left">
          <view class="legend-dot dot-future"></view>
          <text class="legend-name legend-name-future">尚未过去</text>
        </view>
        <view class="legend-right">
          <text class="legend-value legend-value-future">{{futureTime}}</text>
          <text class="legend-pct legend-pct-future">{{futurePercent}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
