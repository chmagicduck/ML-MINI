/* pages/stats/index.wxss — 战报统计页 V2 */

.page {
  min-height: 100vh;
  background: var(--deep-bg);
  display: flex;
  flex-direction: column;
}

/* ===== 头部 ===== */
.header {
  background: linear-gradient(135deg, var(--deep-primary), #2455BC);
  padding: 48rpx 32rpx 56rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
  display: block;
}
.header-sub {
  font-size: 26rpx;
  color: #AFC6F8;
  display: block;
  margin-top: 8rpx;
}

/* ===== 等级卡片 ===== */
.level-card {
  margin: -32rpx 32rpx 0;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  border: 2rpx solid #9E9E9E;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1);
}
.level-card-gold {
  background: linear-gradient(135deg, #FFFDE7, #FFF9C4);
  box-shadow: 0 8rpx 32rpx rgba(255,215,0,0.3);
}
.level-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 20rpx;
}
.level-big-emoji {
  font-size: 80rpx;
}
.level-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.level-title {
  font-size: 44rpx;
  font-weight: 700;
  display: block;
}
.level-desc {
  font-size: 24rpx;
  color: #757575;
  display: block;
}
.gold-text {
  color: #F57F17 !important;
  font-weight: 600;
}
.progress-bar-bg {
  height: 16rpx;
  background: #EEEEEE;
  border-radius: 8rpx;
  overflow: hidden;
  margin-top: 8rpx;
}
.progress-bar-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.5s ease;
}
.progress-pct {
  font-size: 22rpx;
  color: #9E9E9E;
  display: block;
  text-align: right;
  margin-top: 4rpx;
}

/* ===== 累计统计三格 ===== */
.stats-row {
  display: flex;
  flex-direction: row;
  margin: 24rpx 32rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.07);
}
.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.stat-value {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--deep-primary);
  display: block;
}
.stat-label {
  font-size: 22rpx;
  color: #9E9E9E;
  display: block;
}
.stat-divider {
  width: 1rpx;
  background: #EEEEEE;
  margin: 4rpx 0;
}

/* ===== 热力图 ===== */
.section-card {
  margin: 0 32rpx 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.07);
}
.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}
.heatmap-wrap {
  width: 100%;
}
.heatmap-canvas {
  width: 100%;
  height: 140rpx;
  display: block;
}
.legend-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  margin-top: 16rpx;
  justify-content: flex-end;
}
.legend-cell {
  width: 24rpx;
  height: 24rpx;
  border-radius: 4rpx;
}
.legend-text {
  font-size: 20rpx;
  color: #9E9E9E;
}
.heatmap-tip {
  font-size: 24rpx;
  color: #9E9E9E;
  display: block;
  text-align: center;
  padding: 20rpx 0;
}

/* ===== 语录卡片 ===== */
.quote-card {
  margin: 0 32rpx 24rpx;
  background: linear-gradient(135deg, #EAF1FF, #EAF3FF);
  border-radius: 20rpx;
  padding: 28rpx;
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  align-items: flex-start;
}
.quote-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}
.quote-text {
  font-size: 26rpx;
  color: var(--deep-primary);
  line-height: 1.6;
  font-style: italic;
  flex: 1;
}

/* ===== 分享按钮 ===== */
.share-btn-wrap {
  padding: 0 32rpx 24rpx;
}
.share-btn {
  background: linear-gradient(135deg, #3567D2, #2455BC);
  border-radius: 48rpx;
  padding: 28rpx 0;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(76,175,80,0.4);
}
.share-btn:active { opacity: 0.85; }
.share-btn-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
}

/* ===== 隐藏海报 Canvas ===== */
.poster-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 750rpx;
  height: 1000rpx;
}

/* ===== 底部安全区 ===== */
.safe-bottom { height: 120rpx; }
