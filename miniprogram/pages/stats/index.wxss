/* pages/stats/index.wxss — 情报局（待开发） */

.page {
  min-height: 100vh;
  background: #F8FAFC;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.placeholder-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding-bottom: 160rpx;
}

.placeholder-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 16rpx;
}

.placeholder-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #1E293B;
  display: block;
}

.placeholder-desc {
  font-size: 26rpx;
  color: #94A3B8;
  display: block;
  font-weight: 500;
}

.placeholder-dots {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  margin-top: 24rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #CBD5E1;
  animation: dot-bounce 1.4s infinite ease-in-out both;
}

.dot-1 { animation-delay: 0s; }
.dot-2 { animation-delay: 0.2s; }
.dot-3 { animation-delay: 0.4s; }

@keyframes dot-bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}
